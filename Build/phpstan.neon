parameters:
    level: 1
    paths:
      - ../Classes
      - ../Configuration
      - ../Resources
    inferPrivatePropertyTypeFromConstructor: true
    excludePaths:
      - '*/*/ext_localconf.php'
      - '*/*/ext_emconf.php'
      - '*/*/ext_tables.php'
      - '*/Configuration/TCA/*'
      - '*/Configuration/Backend/AjaxRoutes.php'
      - '*/Configuration/Extbase/Persistence/Classes.php'
      - '*/Tests/Unit/*'
      - '*/Build/*'
      - '*/public/*'
      - '*/vendor/*'
